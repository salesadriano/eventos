{
  "name": "eventos-backend",
  "private": true,
  "version": "0.2.0",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "start": "npm run build && node dist/main.js",
    "dev": "tsx watch src/main.ts",
    "test": "jest --config jest.config.ts",
    "test:unit": "jest --config jest.config.ts --selectProjects unit",
    "test:integration": "jest --config jest.config.ts --selectProjects integration",
    "test:coverage": "jest --config jest.config.ts --coverage",
    "test:legacy": "tsx tests-cypress/runCoverage.ts",
    "test:legacy:watch": "xvfb-run -a cypress open --config-file cypress.config.ts",
    "test:coverage:legacy": "c8 --all --src src --exclude tests-cypress/** --exclude dist/** --reporter=text-summary --reporter=lcov --reporter=json-summary tsx tests-cypress/runCoverage.ts"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "chai": "^6.2.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "googleapis": "^144.0.0",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^7.0.10",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@babel/preset-typescript": "^7.28.5",
    "@cypress/code-coverage": "^4.0.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/chai": "^5.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/nodemailer": "^7.0.11",
    "@types/supertest": "^7.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "c8": "^10.1.3",
    "jest": "^30.2.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  },
  "nyc": {
    "all": true,
    "extension": [
      ".ts"
    ],
    "include": [
      "src/**/*.ts"
    ],
    "exclude": [
      "**/*.d.ts",
      "dist/**",
      "tests-cypress/**"
    ],
    "report-dir": "coverage",
    "temp-dir": ".nyc_output"
  }
}
