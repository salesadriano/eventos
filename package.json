{
  "name": "my-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "start": "set NODE_OPTIONS=--max-old-space-size=8192 && vite --host  ",
    "dev": "vite --host 0.0.0.0 --port 5173 --strictPort",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "glossary:sync": "node tools/documentation-glossary/generate-glossary.mjs",
    "cy-run": "xvfb-run -a cypress run",
    "test": "start-server-and-test dev http://localhost:5173 cy-run",
    "test:unit": "vitest run --config vitest.unit.config.ts --coverage",
    "test:unit:watch": "vitest --config vitest.unit.config.ts",
    "test:open": "cypress open",
    "test:watch": "cypress open --config-file cypress.config.ts"
  },
  "dependencies": {
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@storybook/addon-a11y": "^10.2.17",
    "@storybook/addon-vitest": "^10.2.17",
    "@storybook/react-vite": "^10.2.17",
    "@testing-library/cypress": "^10.0.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^24.6.0",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "baseline-browser-mapping": "^2.10.0",
    "cypress": "^15.6.0",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "globals": "^16.4.0",
    "jest-axe": "^10.0.0",
    "jsdom": "^28.1.0",
    "playwright": "^1.58.2",
    "start-server-and-test": "^2.1.3",
    "storybook": "^10.2.17",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.45.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
